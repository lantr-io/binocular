# systemd EnvironmentFile for the Binocular watchtower.
# Install on the box as /var/lib/binocular/secrets.env, owned by the `binocular` user, mode 600:
#   sudo install -o binocular -g binocular -m 600 secrets.env /var/lib/binocular/secrets.env
#
# systemd parses KEY=VALUE. The mnemonic contains spaces, so it MUST be quoted.
# These are the same two values you keep locally in .env (loaded there via direnv); HOCON resolves
# them through ${?WALLET_MNEMONIC} / ${?BLOCKFROST_PROJECT_ID} in application-preprod.conf.

WALLET_MNEMONIC="word1 word2 word3 ... word24"
BLOCKFROST_PROJECT_ID="preprodXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Optional: Discord incoming-webhook URL for operator alerts (new confirmed blocks + loop errors,
# including unrecoverable reorgs). Leave unset to disable notifications.
BIFROST_DISCORD_WEBHOOK="https://discord.com/api/webhooks/XXXXXXXX/XXXXXXXXXXXXXXXXXXXX"
